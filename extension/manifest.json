{
  "manifest_version": 3,
  "name": "HALQ AppFolio Bridge",
  "version": "1.0.5",
  "description": "HALQ Bridge: removes X-Frame-Options/CSP headers for iframe embedding, and enables cross-tab navigation for split view workflow.",
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "permissions": ["declarativeNetRequest", "tabs", "storage"],
  "host_permissions": [
    "*://*.appfolio.com/*",
    "*://outlook.office.com/*",
    "*://outlook.live.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://halq-maintenance-webapp.pages.dev/*",
      "http://localhost:8788/*",
      "http://127.0.0.1:8788/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.appfolio.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://halq-maintenance-webapp.pages.dev/*",
        "http://localhost:8788/*",
        "http://127.0.0.1:8788/*"
      ],
      "js": ["content-halq.js"],
      "run_at": "document_start"
    }
  ]
}
